PORT=3000

# اسم المتجر ورقم الواتساب
STORE_NAME=طاحون الطيب
WHATSAPP_NUMBER=966500611770

# جلب أسعار الشحن / ربط التوصيل
# ملاحظة: وثائق Nitro العامة التي ظهرت لا تعرض بشكل واضح endpoint عام لإنشاء شحنة لمتجرك مباشرة.
# لذلك ضع هنا بياناتك الحقيقية بعد الحصول عليها من لوحة Nitro أو من الدعم الفني لديهم.
NITRO_ENABLED=false
NITRO_BASE_URL=https://svc.nitrocommerce.ai
NITRO_PLATFORM_NAME=your_platform_name
NITRO_PLATFORM_EMAIL=your-platform-email@example.com
NITRO_PLATFORM_PASSWORD=your-platform-password
NITRO_BEARER_TOKEN=
NITRO_ORG_ID=
NITRO_SHIPPING_QUOTE_ENDPOINT=
NITRO_CREATE_SHIPMENT_ENDPOINT=
NITRO_WEBHOOK_SECRET=

# الدفع - Moyasar
# المفتاح العام يمكن استخدامه في الواجهة، أما المفتاح السري فيبقى هنا فقط.
MOYASAR_ENABLED=false
MOYASAR_PUBLISHABLE_KEY=pk_test_replace_me
MOYASAR_SECRET_KEY=sk_test_replace_me
MOYASAR_CALLBACK_URL=http://localhost:3000/payment-return

# الدفع - PayTabs (اختياري)
PAYTABS_ENABLED=false
PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=
PAYTABS_CLIENT_KEY=
PAYTABS_CALLBACK_URL=http://localhost:3000/payment-return

# الدفع - HyperPay / Geidea / غيرها
PAYMENT_PROVIDER=moyasar
